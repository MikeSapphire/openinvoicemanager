<Page x:Class="OpenInvoiceManager.Views.CustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Kunden" Background="#F5F5F5">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Überschrift + Suchleiste -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <TextBlock Text="Kundenverwaltung" FontSize="22" FontWeight="Bold"
                       Foreground="#2C3E50" VerticalAlignment="Center"/>

            <StackPanel Grid.Column="1" Orientation="Horizontal">
                <TextBox x:Name="TxtSearch" Width="200" Height="32"
                         Padding="8,5" BorderBrush="#BDC3C7"
                         KeyUp="TxtSearch_KeyUp"
                         Text="" VerticalContentAlignment="Center"/>
                <Button Content="Suchen" Height="32" Width="70" Margin="5,0,0,0"
                        Background="#2980B9" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnSuchen_Click"/>
                <Button Content="+ Neu" Height="32" Width="70" Margin="5,0,0,0"
                        Background="#27AE60" Foreground="White" BorderThickness="0"
                        Cursor="Hand" Click="BtnNeu_Click"/>
            </StackPanel>
        </Grid>

        <!-- Hauptbereich: Liste links, Formular rechts -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="350"/>
            </Grid.ColumnDefinitions>

            <!-- Kundenliste -->
            <Border Grid.Column="0" Background="White" Margin="0,0,10,0"
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4">
                <ListView x:Name="LvKunden" BorderThickness="0"
                          SelectionChanged="LvKunden_SelectionChanged">
                    <ListView.View>
                        <GridView>
                            <GridViewColumn Header="Name" Width="160"
                                            DisplayMemberBinding="{Binding Name}"/>
                            <GridViewColumn Header="Stadt" Width="120"
                                            DisplayMemberBinding="{Binding City}"/>
                            <GridViewColumn Header="Email" Width="180"
                                            DisplayMemberBinding="{Binding Email}"/>
                            <GridViewColumn Header="Telefon" Width="120"
                                            DisplayMemberBinding="{Binding Phone}"/>
                        </GridView>
                    </ListView.View>
                </ListView>
            </Border>

            <!-- Formular -->
            <Border Grid.Column="1" Background="White"
                    BorderBrush="#E0E0E0" BorderThickness="1" CornerRadius="4"
                    Padding="15">
                <StackPanel>
                    <TextBlock x:Name="TxtFormTitle" Text="Neuer Kunde"
                               FontSize="16" FontWeight="Bold" Foreground="#2C3E50"
                               Margin="0,0,0,15"/>

                    <TextBlock Text="Name *" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtName" Height="30" Padding="8,5"
                             BorderBrush="#BDC3C7" Margin="0,0,0,10"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="Straße" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtStreet" Height="30" Padding="8,5"
                             BorderBrush="#BDC3C7" Margin="0,0,0,10"
                             VerticalContentAlignment="Center"/>

                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <TextBlock Text="PLZ" Foreground="#555" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtZip" Height="30" Padding="8,5"
                                     BorderBrush="#BDC3C7"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Stadt" Foreground="#555" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCity" Height="30" Padding="8,5"
                                     BorderBrush="#BDC3C7"
                                     VerticalContentAlignment="Center"/>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Email" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtEmail" Height="30" Padding="8,5"
                             BorderBrush="#BDC3C7" Margin="0,0,0,10"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Text="Telefon" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox x:Name="TxtPhone" Height="30" Padding="8,5"
                             BorderBrush="#BDC3C7" Margin="0,0,0,20"
                             VerticalContentAlignment="Center"/>

                    <!-- Buttons -->
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnSpeichern" Content="Speichern"
                                Height="35" Width="100"
                                Background="#27AE60" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnSpeichern_Click"/>
                        <Button x:Name="BtnLoeschen" Content="Löschen"
                                Height="35" Width="80" Margin="8,0,0,0"
                                Background="#E74C3C" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnLoeschen_Click"
                                IsEnabled="False"/>
                        <Button Content="Abbrechen"
                                Height="35" Width="90" Margin="8,0,0,0"
                                Background="#95A5A6" Foreground="White"
                                BorderThickness="0" Cursor="Hand"
                                Click="BtnAbbrechen_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
