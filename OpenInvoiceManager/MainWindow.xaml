<Window x:Class="OpenInvoiceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Open Invoice Manager" Height="650" Width="1050"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Seitenleiste / Navigation -->
        <Border Grid.Column="0" Background="#2C3E50">
            <StackPanel Margin="0,20,0,0">
                <TextBlock Text="Open Invoice" Foreground="White"
                           FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Center" Margin="0,0,0,5"/>
                <TextBlock Text="Manager" Foreground="#BDC3C7"
                           FontSize="12"
                           HorizontalAlignment="Center" Margin="0,0,0,30"/>

                <Button x:Name="BtnKunden" Content="Kunden"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnKunden_Click"/>
                <Button x:Name="BtnRechnungen" Content="Rechnungen"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnRechnungen_Click"/>
                <Button x:Name="BtnArtikel" Content="Artikel"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnArtikel_Click"/>
                <Button x:Name="BtnEinstellungen" Content="Einstellungen"
                        Style="{StaticResource NavButtonStyle}"
                        Click="BtnEinstellungen_Click"/>
            </StackPanel>
        </Border>

        <!-- Hauptbereich - hier werden die Pages geladen -->
        <Frame x:Name="MainFrame" Grid.Column="1"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Window>
